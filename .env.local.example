# Supabase — required for auth + multi-device sync. Without these the app
# runs in guest mode (IndexedDB only). See README → Supabase setup.
#
# Use the new "API keys" naming (rolled out late 2024/2025):
#   - Publishable key (prefix `sb_publishable_…`) goes in the browser.
#   - Secret key (prefix `sb_secret_…`) is server-only — bypasses RLS.
# Legacy `anon` JWTs still work if pasted into PUBLISHABLE_KEY; the SDK
# accepts either format.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only — never expose. Required for the "Delete account" button in
# Settings (the /api/delete-account route uses it to call
# auth.admin.deleteUser). Leave unset to disable the button: the route
# returns 503 and the UI surfaces a "not configured" message instead.
# SUPABASE_SECRET_KEY=
